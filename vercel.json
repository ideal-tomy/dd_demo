{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/ai", "destination": "/ai.html" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/trial/ask.ts": { "memory": 1024, "maxDuration": 60 },
    "api/trial/status.ts": { "memory": 512, "maxDuration": 15 }
  }
}
